[54.610846, "o", "  \u001b[1;32mвң“\u001b[0m  Tasks submitted вҶ’ coordinator decomposed & dispatched subtasks\r\n  \u001b[1;32mвң“\u001b[0m  LLM-as-a-Judge evaluated each result (asymmetric loss function)\r\n  \u001b[1;32mвң“\u001b[0m  Rewards distributed proportional to contribution scores\r\n  \u001b[1;32mвң“\u001b[0m  Trust scores evolved вҖ” strong agents rose, weak agents fell\r\n  \u001b[1;32mвң“\u001b[0m  Full causal chain recorded for transparency\r\n\r\n  \u001b[1mThe best agent earned the most. Automatically. On-chain.\u001b[0m\r\n\r\n  \u001b[2mAPI docs:  http://127.0.0.1:8000/docs\u001b[0m\r\n  \u001b[2mGitHub:    https://github.com/makinzm/rutsubo\u001b[0m\r\n\r\n"]
