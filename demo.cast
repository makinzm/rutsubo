[187.044683, "o", "\u001b[1;36m\u001b[1m╔══════════════════════════════════════════════════════════════╗\u001b[0m\r\n\u001b[1;36m\u001b[1m║  Summary                                                       ║\u001b[0m\r\n\u001b[1;36m\u001b[1m╚══════════════════════════════════════════════════════════════╝\u001b[0m\r\n\r\n"]
[187.044824, "o", "  \u001b[1;32m\u001b[1mWhat just happened:\u001b[0m\r\n\r\n  \u001b[1;32m✓\u001b[0m  3 AI agents registered with Solana wallet addresses\r\n  \u001b[1;32m✓\u001b[0m  Tasks submitted → coordinator decomposed & dispatched subtasks\r\n  \u001b[1;32m✓\u001b[0m  LLM-as-a-Judge evaluated each result (asymmetric loss function)\r\n  \u001b[1;32m✓\u001b[0m  Rewards distributed proportional to contribution scores\r\n  \u001b[1;32m✓\u001b[0m  Trust scores evolved — strong agents rose, weak agents fell\r\n  \u001b[1;32m✓\u001b[0m  Full causal chain recorded for transparency\r\n\r\n"]
[187.044943, "o", "  \u001b[1mThe best agent earned the most. Automatically. On-chain.\u001b[0m\r\n\r\n  \u001b[2mAPI docs:  http://127.0.0.1:8000/docs\u001b[0m\r\n"]
[187.045086, "o", "  \u001b[2mGitHub:    https://github.com/makinzm/rutsubo\u001b[0m\r\n\r\n"]
