[97.193348, "o", "\u001b[1;36m\u001b[1m║  Step 4 — Causal Chain Visualization                         ║\u001b[0m\r\n\u001b[1;36m\u001b[1m╚══════════════════════════════════════════════════════════════╝\u001b[0m\r\n\r\n  \u001b[2mRutsubo records which layer contributed what — so you can trace\u001b[0m\r\n  \u001b[2mexactly why a task succeeded or failed.\u001b[0m\r\n\r\n"]
[97.290459, "o", "  \u001b[1m4 causal chain entries recorded:\u001b[0m\r\n\r\n"]
[97.30788, "o", "  layer=worker      agent=?                     score=0.10    reward=—\r\n  layer=worker      agent=?                     score=0.45    reward=—\r\n  layer=worker      agent=?                     score=0.42    reward=—\r\n  layer=worker      agent=?                     score=0.20    reward=—\r\n"]
[101.317886, "o", "\r\n"]
[101.318261, "o", "\u001b[1;36m\u001b[1m╔══════════════════════════════════════════════════════════════╗\u001b[0m\r\n\u001b[1;36m\u001b[1m║  Step 5 — Dashboard: Trust Score Evolution                   ║\u001b[0m\r\n\u001b[1;36m\u001b[1m╚══════════════════════════════════════════════════════════════╝\u001b[0m\r\n\r\n  \u001b[2mAfter each task, trust_score updates via exponential moving average:\u001b[0m\r\n  \u001b[2m  new = 0.8 × old + 0.2 × eval_score\u001b[0m\r\n\r\n  \u001b[1mAgent performance after 1 task:\u001b[0m\r\n"]
[101.318411, "o", "\r\n"]
[101.374168, "o", "  HighQualityAgent     [█████████░░░░░░░░░░░] 0.487   reward=0.1184 SOL  tasks=2\r\n  WeakAgent            [████████░░░░░░░░░░░░] 0.440   reward=0.0272 SOL  tasks=1\r\n  SpecialistAgent      [████████░░░░░░░░░░░░] 0.420   reward=0.0136 SOL  tasks=1\r\n"]
[101.37736, "o", "\r\n"]
[101.377429, "o", "  \u001b[2mHigh-quality agents gain trust. Weak agents lose trust.\u001b[0m\r\n  \u001b[2mOver many tasks, the best agents naturally dominate selection.\u001b[0m\r\n"]
[105.386273, "o", "\r\n"]
